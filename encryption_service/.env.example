# =============================================================================
# Helios Encryption Service — Variables de Entorno
# =============================================================================

# Clave de cifrado AES-256 en formato hexadecimal (64 caracteres = 32 bytes).
# Si se deja vacía, el servicio generará una clave temporal al arrancar.
# IMPORTANTE: En producción, SIEMPRE configura una clave fija.
ENCRYPTION_KEY=

# Puerto del servidor gRPC (por defecto: 50051)
GRPC_PORT=50051

# Puerto de la API REST / health check (por defecto: 8000)
API_PORT=8000
